# Copy to .env for local development - never commit .env to git
# On Vercel, set these in the project environment variables dashboard

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/mern-auth?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Local dev frontend URL
CLIENT_URL=http://localhost:5173

# Gmail App Password (NOT your account password)
# https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
